@model IEnumerable<DMST.Models.Campaign>
<h2>Campaigns</h2>
<a asp-action="Create">+ New</a>
<table border="1">
    <tr>
        <th>Name</th>
        <th>Start</th>
        <th>Setting</th>
        <th></th>
    </tr>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.Name</td>
            <td>@c.StartDate</td>
            <td>@c.Setting</td>
            <td>
                <a asp-action="Details" asp-route-id="@c.CampaignId">Details</a> |
                <a asp-action="Edit" asp-route-id="@c.CampaignId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@c.CampaignId">Delete</a>
            </td>
        </tr>
    }
</table>