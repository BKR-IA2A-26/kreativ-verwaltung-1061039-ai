@model DMST.Models.Campaign
<h2>Edit Campaign</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="CampaignId" />
    Name: <input asp-for="Name" /><br />
    Start: <input asp-for="StartDate" type="date" /><br />
    Setting: <input asp-for="Setting" /><br />
    <button type="submit">Speichern</button>
    <a asp-action="Index">Zurück</a>
</form>